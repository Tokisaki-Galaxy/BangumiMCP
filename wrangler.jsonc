{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "bangumi-mcp",
  "main": "src/worker.py",
  "compatibility_date": "2026-04-20",
  "compatibility_flags": [
    "python_workers",
    "python_dedicated_snapshot"
  ],
  "placement": {
    "mode": "smart"
  },
  "observability": {
    "enabled": true
  }
}
